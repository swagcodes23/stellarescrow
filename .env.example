# ─────────────────────────────────────────────────
# Rental Deposit Escrow — Environment Configuration
# ─────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# All variables are prefixed with REACT_APP_ for CRA compatibility.

# Stellar Network (TESTNET or PUBLIC)
REACT_APP_STELLAR_NETWORK=TESTNET
REACT_APP_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# RPC & Horizon Endpoints
REACT_APP_HORIZON_URL=https://horizon-testnet.stellar.org
REACT_APP_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Contract Addresses (deployed on Testnet)
REACT_APP_ESCROW_CONTRACT_ID=CDTQUZTEFN3GWEPKRCRD4ABGMYIZUQDSLEL6SF4SSO4EJGQVXTC7QXBV
REACT_APP_NATIVE_TOKEN_CONTRACT=CDLZFC3SYJYDZT7K67VZ75HPJVIEUVNIXF47ZG2FB2RMQQVU2HHGCYSC

# Event Polling (milliseconds)
REACT_APP_EVENT_POLL_INTERVAL=5000
REACT_APP_EVENT_LEDGER_LOOKBACK=1000

# Transaction Settings
REACT_APP_DEFAULT_FEE=100000
REACT_APP_TX_TIMEOUT=30
REACT_APP_MAX_RETRIES=25
